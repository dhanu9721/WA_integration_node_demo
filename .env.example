# Server
PORT=3000

# AiSensy credentials
AISENSY_PROJECT_ID=69e9d846c846400de391746c
AISENSY_API_PWD=82adda718b8bd982f833e

# WhatsApp recipient (must include country code — e.g. 918858318301)
AISENSY_TO=918858318301

# First call — text message
AISENSY_TEXT_BODY=hello test

# Second call — document message (sent DELAY_BETWEEN_CALLS_MS after the text)
AISENSY_DOC_LINK=https://s3.ap-south-1.amazonaws.com/pibpl-fe-prod.paytminsurance.co.in/pdf/IndiaFirst%20Life%20Protect%20Shield%20Plan_Brochure.pdf
AISENSY_DOC_CAPTION=Your document caption here
AISENSY_DOC_FILENAME=wds

# Gap between the two calls, in milliseconds
DELAY_BETWEEN_CALLS_MS=5000

# CORS — comma-separated list, or * for all (demo only).
ALLOWED_ORIGINS=*
